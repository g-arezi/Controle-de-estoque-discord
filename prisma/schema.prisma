// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(dbgenerated("'prod_' || substr(md5(random()::text || clock_timestamp()::text), 1, 20)")) @db.VarChar(30)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int      @default(0)
  category    String   @db.VarChar(100)
  type        String   @db.VarChar(50) @default("DIGITAL")
  channelId   String?  @db.VarChar(30)
  imageUrl    String?  @db.Text
  videoUrl    String?  @db.Text
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]

  @@index([status])
  @@index([category])
  @@index([channelId])
  @@map("products")
}

model ProductTypeConfig {
  id          String   @id @default(dbgenerated("'type_' || substr(md5(random()::text || clock_timestamp()::text), 1, 20)")) @db.VarChar(30)
  name        String   @unique @db.VarChar(50)
  description String?  @db.Text
  emoji       String?  @db.VarChar(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("product_types")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model Order {
  id              String   @id @default(dbgenerated("'ord_' || substr(md5(random()::text || clock_timestamp()::text), 1, 20)")) @db.VarChar(30)
  discordUserId   String   @db.VarChar(30)
  discordUsername String   @db.VarChar(255)
  productId       String   @db.VarChar(30)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity        Int      @default(1)
  totalPrice      Decimal  @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  paymentId       String?  @db.VarChar(255)
  paymentUrl      String?  @db.Text
  pixKey          String?  @db.Text
  expiresAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([discordUserId])
  @@index([status])
  @@index([productId])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  EXPIRED
}

model RateLimit {
  id          String   @id @default(uuid())
  discordUserId String  @db.VarChar(30)
  action      String   @db.VarChar(100)
  count       Int      @default(1)
  resetAt     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([discordUserId, action, resetAt])
  @@index([discordUserId])
  @@map("rate_limits")
}

model AuditLog {
  id          String   @id @default(uuid())
  discordUserId String  @db.VarChar(30)
  discordUsername String  @db.VarChar(255)
  action      String   @db.VarChar(100)
  entity      String   @db.VarChar(50)
  entityId    String?  @db.VarChar(255)
  details     String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([discordUserId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
